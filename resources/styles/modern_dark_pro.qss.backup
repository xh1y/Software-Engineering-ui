/* ============================================================================
   OptiKG - Modern Dark Professional Theme
   现代深色专业主题 - 不是纯黑，而是深灰，护眼舒适
   遵循 60-30-10 法则、8pt 网格、优雅阴影
   ============================================================================ */

/* ----------------------------------------------------------------------------
   设计令牌 (Design Tokens)
   ---------------------------------------------------------------------------- */

/* 基础色板 - 深色模式 */
* {
    /* 主色调 - 靛蓝，在深色模式下更亮 */
    --color-primary-400: #818cf8;
    --color-primary-500: #6366f1;
    --color-primary-600: #4f46e5;
    
    /* 中性色 - 深灰阶 (注意：不是纯黑!) */
    --color-gray-0: #0f0f0f;        /* 最深的背景 */
    --color-gray-50: #171717;       /* 主背景 */
    --color-gray-100: #1f1f1f;      /* 卡片背景 */
    --color-gray-200: #2a2a2a;      /* 边框 */
    --color-gray-300: #404040;      /* 输入框边框 */
    --color-gray-400: #525252;      /* 禁用状态 */
    --color-gray-500: #737373;      /* 次要文字 */
    --color-gray-600: #a3a3a3;      /* 辅助文字 */
    --color-gray-700: #d4d4d4;      /* 正文 */
    --color-gray-800: #e5e5e5;      /* 标题 */
    --color-gray-900: #f5f5f5;      /* 最亮文字 */
    
    /* 语义色 - 在深色模式下调整亮度 */
    --color-success-400: #4ade80;
    --color-success-500: #22c55e;
    --color-success-600: #16a34a;
    --color-warning-400: #fbbf24;
    --color-warning-500: #f59e0b;
    --color-warning-600: #d97706;
    --color-error-400: #f87171;
    --color-error-500: #ef4444;
    --color-error-600: #dc2626;
    --color-info-400: #60a5fa;
    --color-info-500: #3b82f6;
    --color-info-600: #2563eb;
    
    /* 间距 - 8pt 网格 */
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 20px;
    --space-6: 24px;
    --space-8: 32px;
    --space-10: 40px;
    
    /* 圆角 */
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-lg: 8px;
    --radius-xl: 12px;
    
    /* 阴影 - 深色模式下阴影更柔和 */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -2px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -4px rgba(0, 0, 0, 0.5);
    
    /* 字体 - 专为中文工业软件优化 */
    --font-sans: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "WenQuanYi Micro Hei", "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    
    /* 字号 */
    --text-xs: 11px;
    --text-sm: 12px;
    --text-base: 13px;
    --text-md: 14px;
    --text-lg: 16px;
    --text-xl: 18px;
    --text-2xl: 20px;
    
    --font-normal: 400;
    --font-medium: 500;
    --font-semibold: 600;
    --font-bold: 700;
    
    /* 过渡 */
    --transition-fast: 150ms ease;
}

/* ----------------------------------------------------------------------------
   全局基础样式
   ---------------------------------------------------------------------------- */
QWidget {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-gray-700);
    selection-background-color: rgba(99, 102, 241, 0.4);
    selection-color: var(--color-gray-900);
}

/* ----------------------------------------------------------------------------
   主窗口 - 深灰背景 (#171717)，不是纯黑
   ---------------------------------------------------------------------------- */
QMainWindow {
    background-color: var(--color-gray-50);
    border: none;
}

/* ----------------------------------------------------------------------------
   菜单栏
   ---------------------------------------------------------------------------- */
QMenuBar {
    background-color: var(--color-gray-100);
    border-bottom: 1px solid var(--color-gray-200);
    padding: var(--space-2) var(--space-4);
    min-height: 40px;
}

QMenuBar::item {
    background-color: transparent;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    margin: 0 var(--space-1);
    color: var(--color-gray-600);
    font-weight: var(--font-medium);
}

QMenuBar::item:selected {
    background-color: rgba(99, 102, 241, 0.15);
    color: var(--color-primary-400);
}

QMenuBar::item:pressed {
    background-color: rgba(99, 102, 241, 0.25);
}

/* ----------------------------------------------------------------------------
   菜单
   ---------------------------------------------------------------------------- */
QMenu {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-2);
    box-shadow: var(--shadow-lg);
}

QMenu::item {
    padding: var(--space-3) var(--space-5);
    padding-left: var(--space-8);
    border-radius: var(--radius-md);
    margin: var(--space-1) 0;
    color: var(--color-gray-700);
    font-weight: var(--font-medium);
}

QMenu::item:selected {
    background-color: rgba(99, 102, 241, 0.15);
    color: var(--color-primary-400);
}

QMenu::separator {
    height: 1px;
    background-color: var(--color-gray-200);
    margin: var(--space-2) var(--space-3);
}

/* ----------------------------------------------------------------------------
   工具栏
   ---------------------------------------------------------------------------- */
QToolBar {
    background-color: var(--color-gray-100);
    border: none;
    border-bottom: 1px solid var(--color-gray-200);
    padding: var(--space-3) var(--space-4);
    spacing: var(--space-2);
}

QToolBar::separator {
    width: 1px;
    background-color: var(--color-gray-200);
    margin: var(--space-2) var(--space-3);
}

/* ----------------------------------------------------------------------------
   工具按钮
   ---------------------------------------------------------------------------- */
QToolButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    color: var(--color-gray-600);
    font-weight: var(--font-medium);
}

QToolButton:hover {
    background-color: var(--color-gray-200);
    border-color: var(--color-gray-300);
    color: var(--color-gray-800);
}

QToolButton:pressed {
    background-color: var(--color-gray-300);
}

QToolButton:checked {
    background-color: rgba(99, 102, 241, 0.15);
    border-color: rgba(99, 102, 241, 0.3);
    color: var(--color-primary-400);
}

/* ----------------------------------------------------------------------------
   按钮
   ---------------------------------------------------------------------------- */
QPushButton {
    background-color: var(--color-gray-200);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-5);
    color: var(--color-gray-800);
    font-weight: var(--font-semibold);
    font-size: var(--text-md);
    min-height: 36px;
    min-width: 80px;
}

QPushButton:hover {
    background-color: var(--color-gray-300);
    border-color: var(--color-gray-400);
}

QPushButton:pressed {
    background-color: var(--color-gray-400);
}

QPushButton:disabled {
    background-color: var(--color-gray-100);
    color: var(--color-gray-500);
    border-color: var(--color-gray-200);
}

QPushButton:focus {
    border-color: var(--color-primary-500);
}

/* 主要按钮 - 亮色强调 */
QPushButton#extractBtn,
QPushButton#primaryBtn {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
    color: white;
    box-shadow: var(--shadow-sm);
}

QPushButton#extractBtn:hover,
QPushButton#primaryBtn:hover {
    background-color: var(--color-primary-500);
    border-color: var(--color-primary-500);
    box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
}

QPushButton#extractBtn:pressed,
QPushButton#primaryBtn:pressed {
    background-color: var(--color-primary-600);
    box-shadow: none;
}

/* 危险按钮 */
QPushButton#clearBtn,
QPushButton#deleteBtn,
QPushButton#dangerBtn {
    background-color: var(--color-error-600);
    border-color: var(--color-error-600);
    color: white;
}

QPushButton#clearBtn:hover,
QPushButton#deleteBtn:hover,
QPushButton#dangerBtn:hover {
    background-color: var(--color-error-500);
    border-color: var(--color-error-500);
}

/* 次要按钮 */
QPushButton#secondaryBtn {
    background-color: transparent;
    border-color: var(--color-gray-400);
    color: var(--color-gray-600);
}

QPushButton#secondaryBtn:hover {
    background-color: var(--color-gray-200);
    border-color: var(--color-gray-500);
    color: var(--color-gray-800);
}

/* 成功按钮 */
QPushButton#successBtn {
    background-color: var(--color-success-600);
    border-color: var(--color-success-600);
    color: white;
}

QPushButton#successBtn:hover {
    background-color: var(--color-success-500);
    border-color: var(--color-success-500);
}

/* ----------------------------------------------------------------------------
   文本编辑框
   ---------------------------------------------------------------------------- */
QTextEdit {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    color: var(--color-gray-800);
    font-size: var(--text-md);
    line-height: 1.6;
    selection-background-color: rgba(99, 102, 241, 0.3);
}

QTextEdit:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
}

QTextEdit:disabled {
    background-color: var(--color-gray-50);
    color: var(--color-gray-500);
    border-color: var(--color-gray-200);
}

QTextEdit::placeholder {
    color: var(--color-gray-500);
}

/* ----------------------------------------------------------------------------
   单行输入框
   ---------------------------------------------------------------------------- */
QLineEdit {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    color: var(--color-gray-800);
    font-size: var(--text-md);
    min-height: 36px;
}

QLineEdit:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
}

QLineEdit:disabled {
    background-color: var(--color-gray-50);
    color: var(--color-gray-500);
}

QLineEdit::placeholder {
    color: var(--color-gray-500);
}

/* ----------------------------------------------------------------------------
   标签
   ---------------------------------------------------------------------------- */
QLabel {
    color: var(--color-gray-700);
    background-color: transparent;
}

QLabel#titleLabel {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-2);
}

QLabel#subtitleLabel {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--color-gray-800);
}

QLabel#descriptionLabel {
    font-size: var(--text-base);
    color: var(--color-gray-600);
    line-height: 1.5;
}

QLabel#hintLabel {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
}

QLabel#charCountLabel {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    font-weight: var(--font-medium);
}

/* ----------------------------------------------------------------------------
   分组框 - 深灰卡片
   ---------------------------------------------------------------------------- */
QGroupBox {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    margin-top: var(--space-6);
    padding: var(--space-6);
    font-weight: var(--font-semibold);
    color: var(--color-gray-800);
    box-shadow: var(--shadow-sm);
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: var(--space-4);
    padding: 0 var(--space-2);
    color: var(--color-gray-700);
    font-size: var(--text-md);
}

/* ----------------------------------------------------------------------------
   标签页
   ---------------------------------------------------------------------------- */
QTabWidget::pane {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    top: -1px;
    padding: var(--space-4);
}

QTabBar::tab {
    background-color: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: var(--space-3) var(--space-5);
    margin-right: var(--space-1);
    color: var(--color-gray-500);
    font-weight: var(--font-medium);
    font-size: var(--text-md);
}

QTabBar::tab:selected {
    color: var(--color-primary-400);
    border-bottom-color: var(--color-primary-500);
}

QTabBar::tab:hover:!selected {
    color: var(--color-gray-700);
    background-color: var(--color-gray-200);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
}

/* ----------------------------------------------------------------------------
   树形控件
   ---------------------------------------------------------------------------- */
QTreeWidget {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-2);
    outline: none;
    alternate-background-color: var(--color-gray-50);
}

QTreeWidget::item {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    margin: var(--space-1) var(--space-2);
    min-height: 32px;
}

QTreeWidget::item:selected {
    background-color: rgba(99, 102, 241, 0.15);
    color: var(--color-primary-400);
}

QTreeWidget::item:hover:!selected {
    background-color: var(--color-gray-200);
}

QHeaderView::section {
    background-color: var(--color-gray-50);
    padding: var(--space-3) var(--space-4);
    border: none;
    border-bottom: 1px solid var(--color-gray-200);
    font-weight: var(--font-semibold);
    color: var(--color-gray-700);
    font-size: var(--text-sm);
}

/* ----------------------------------------------------------------------------
   列表控件
   ---------------------------------------------------------------------------- */
QListWidget {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-2);
    outline: none;
}

QListWidget::item {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    margin: var(--space-1) 0;
}

QListWidget::item:selected {
    background-color: rgba(99, 102, 241, 0.15);
    color: var(--color-primary-400);
}

QListWidget::item:hover:!selected {
    background-color: var(--color-gray-200);
}

/* ----------------------------------------------------------------------------
   表格
   ---------------------------------------------------------------------------- */
QTableWidget {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    gridline-color: var(--color-gray-200);
    outline: none;
}

QTableWidget::item {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-gray-200);
}

QTableWidget::item:selected {
    background-color: rgba(99, 102, 241, 0.15);
    color: var(--color-primary-400);
}

QTableWidget::item:hover:!selected {
    background-color: var(--color-gray-50);
}

QTableCornerButton::section {
    background-color: var(--color-gray-50);
    border: none;
}

/* ----------------------------------------------------------------------------
   复选框
   ---------------------------------------------------------------------------- */
QCheckBox {
    spacing: var(--space-3);
    color: var(--color-gray-700);
    font-weight: var(--font-medium);
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-gray-400);
    border-radius: var(--radius-sm);
    background-color: var(--color-gray-100);
}

QCheckBox::indicator:hover {
    border-color: var(--color-primary-500);
}

QCheckBox::indicator:checked {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
}

QCheckBox::indicator:disabled {
    border-color: var(--color-gray-300);
    background-color: var(--color-gray-50);
}

/* ----------------------------------------------------------------------------
   单选按钮
   ---------------------------------------------------------------------------- */
QRadioButton {
    spacing: var(--space-3);
    color: var(--color-gray-700);
    font-weight: var(--font-medium);
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-gray-400);
    border-radius: 9px;
    background-color: var(--color-gray-100);
}

QRadioButton::indicator:hover {
    border-color: var(--color-primary-500);
}

QRadioButton::indicator:checked {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
}

/* ----------------------------------------------------------------------------
   下拉框
   ---------------------------------------------------------------------------- */
QComboBox {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    padding-right: var(--space-10);
    color: var(--color-gray-800);
    font-weight: var(--font-medium);
    min-height: 36px;
    min-width: 120px;
}

QComboBox:hover {
    border-color: var(--color-gray-400);
}

QComboBox:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
}

QComboBox::drop-down {
    border: none;
    width: 32px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid var(--color-gray-500);
    width: 0;
    height: 0;
}

QComboBox QAbstractItemView {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--space-2);
    selection-background-color: rgba(99, 102, 241, 0.15);
    selection-color: var(--color-primary-400);
    box-shadow: var(--shadow-lg);
}

/* ----------------------------------------------------------------------------
   滑动条
   ---------------------------------------------------------------------------- */
QSlider::groove:horizontal {
    height: 6px;
    background-color: var(--color-gray-300);
    border-radius: 3px;
}

QSlider::sub-page:horizontal {
    background-color: var(--color-primary-500);
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 18px;
    height: 18px;
    margin: -6px 0;
    background-color: var(--color-gray-800);
    border: 2px solid var(--color-primary-500);
    border-radius: 9px;
    box-shadow: var(--shadow-sm);
}

QSlider::handle:horizontal:hover {
    background-color: var(--color-gray-900);
    box-shadow: 0 0 10px rgba(99, 102, 241, 0.5);
}

/* ----------------------------------------------------------------------------
   进度条
   ---------------------------------------------------------------------------- */
QProgressBar {
    background-color: var(--color-gray-300);
    border-radius: var(--radius-lg);
    text-align: center;
    color: var(--color-gray-900);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    min-height: 8px;
    max-height: 8px;
}

QProgressBar::chunk {
    background-color: var(--color-primary-500);
    border-radius: var(--radius-lg);
}

/* ----------------------------------------------------------------------------
   状态栏
   ---------------------------------------------------------------------------- */
QStatusBar {
    background-color: var(--color-gray-100);
    border-top: 1px solid var(--color-gray-200);
    padding: var(--space-2) var(--space-4);
    min-height: 32px;
}

QStatusBar QLabel {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    padding: 0 var(--space-4);
}

/* ----------------------------------------------------------------------------
   滚动条
   ---------------------------------------------------------------------------- */
QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    margin: 4px 2px;
}

QScrollBar::handle:vertical {
    background-color: var(--color-gray-500);
    border-radius: 4px;
    min-height: 40px;
}

QScrollBar::handle:vertical:hover {
    background-color: var(--color-gray-600);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background-color: transparent;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 8px;
    margin: 2px 4px;
}

QScrollBar::handle:horizontal {
    background-color: var(--color-gray-500);
    border-radius: 4px;
    min-width: 40px;
}

QScrollBar::handle:horizontal:hover {
    background-color: var(--color-gray-600);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
}

/* ----------------------------------------------------------------------------
   对话框
   ---------------------------------------------------------------------------- */
QDialog {
    background-color: var(--color-gray-50);
}

/* ----------------------------------------------------------------------------
   分割器
   ---------------------------------------------------------------------------- */
QSplitter::handle {
    background-color: var(--color-gray-200);
}

QSplitter::handle:horizontal {
    width: 2px;
    margin: 0 2px;
}

QSplitter::handle:vertical {
    height: 2px;
    margin: 2px 0;
}

QSplitter::handle:hover {
    background-color: var(--color-primary-500);
}

/* ----------------------------------------------------------------------------
   工具提示
   ---------------------------------------------------------------------------- */
QToolTip {
    background-color: var(--color-gray-800);
    color: var(--color-gray-900);
    border: 1px solid var(--color-gray-700);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
}

/* ----------------------------------------------------------------------------
   微调框
   ---------------------------------------------------------------------------- */
QSpinBox, QDoubleSpinBox {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    min-height: 36px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
}

QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    border: none;
    background-color: transparent;
    width: 20px;
}

/* ----------------------------------------------------------------------------
   日期时间编辑器
   ---------------------------------------------------------------------------- */
QDateTimeEdit {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    min-height: 36px;
}

QDateTimeEdit:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
}

/* ----------------------------------------------------------------------------
   框架
   ---------------------------------------------------------------------------- */
QFrame {
    border: none;
}

QFrame#cardFrame {
    background-color: var(--color-gray-100);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
}

/* ----------------------------------------------------------------------------
   特殊状态
   ---------------------------------------------------------------------------- */
QLabel#successText {
    color: var(--color-success-400);
}

QLabel#warningText {
    color: var(--color-warning-400);
}

QLabel#errorText {
    color: var(--color-error-400);
}

QLabel#infoText {
    color: var(--color-info-400);
}
