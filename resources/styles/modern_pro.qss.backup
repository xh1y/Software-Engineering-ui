/* ============================================================================
   OptiKG - Modern Professional Theme
   现代专业主题 - 基于 8pt 网格系统、60-30-10 色彩法则、优雅阴影设计
   ============================================================================ */

/* ----------------------------------------------------------------------------
   设计令牌 (Design Tokens) - 全局变量
   ---------------------------------------------------------------------------- */

/* 基础色板 */
* {
    /* 主色调 - 靛蓝 (Indigo) */
    --color-primary-50: #eef2ff;
    --color-primary-100: #e0e7ff;
    --color-primary-200: #c7d2fe;
    --color-primary-500: #6366f1;
    --color-primary-600: #4f46e5;
    --color-primary-700: #4338ca;
    
    /* 中性色 - 灰阶 (Neutral Gray Scale) */
    --color-gray-0: #ffffff;
    --color-gray-50: #fafafa;
    --color-gray-100: #f5f5f5;
    --color-gray-200: #e5e5e5;
    --color-gray-300: #d4d4d4;
    --color-gray-400: #a3a3a3;
    --color-gray-500: #737373;
    --color-gray-600: #525252;
    --color-gray-700: #404040;
    --color-gray-800: #262626;
    --color-gray-900: #171717;
    
    /* 语义色 - 成功、警告、错误、信息 */
    --color-success-50: #f0fdf4;
    --color-success-500: #22c55e;
    --color-success-600: #16a34a;
    --color-warning-50: #fffbeb;
    --color-warning-500: #f59e0b;
    --color-warning-600: #d97706;
    --color-error-50: #fef2f2;
    --color-error-500: #ef4444;
    --color-error-600: #dc2626;
    --color-info-50: #eff6ff;
    --color-info-500: #3b82f6;
    --color-info-600: #2563eb;
    
    /* 间距 - 8pt 网格系统 */
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 20px;
    --space-6: 24px;
    --space-8: 32px;
    --space-10: 40px;
    
    /* 圆角 */
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-lg: 8px;
    --radius-xl: 12px;
    
    /* 阴影 - 柔和的多层阴影 */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    
    /* 字体 - 专为中文工业软件优化 */
    --font-sans: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "WenQuanYi Micro Hei", "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "JetBrains Mono", "Fira Code", "Source Code Pro", Consolas, monospace;
    
    /* 字号与字重 */
    --text-xs: 11px;
    --text-sm: 12px;
    --text-base: 13px;
    --text-md: 14px;
    --text-lg: 16px;
    --text-xl: 18px;
    --text-2xl: 20px;
    
    --font-normal: 400;
    --font-medium: 500;
    --font-semibold: 600;
    --font-bold: 700;
    
    /* 过渡动画 */
    --transition-fast: 150ms ease;
    --transition-base: 200ms ease;
    --transition-slow: 300ms ease;
}

/* ----------------------------------------------------------------------------
   全局基础样式
   ---------------------------------------------------------------------------- */
QWidget {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-gray-700);
    selection-background-color: var(--color-primary-200);
    selection-color: var(--color-gray-900);
}

/* ----------------------------------------------------------------------------
   主窗口 - 60% 背景色 (白色/浅灰)
   ---------------------------------------------------------------------------- */
QMainWindow {
    background-color: var(--color-gray-50);
    border: none;
}

/* ----------------------------------------------------------------------------
   菜单栏 - 简洁扁平
   ---------------------------------------------------------------------------- */
QMenuBar {
    background-color: var(--color-gray-0);
    border-bottom: 1px solid var(--color-gray-200);
    padding: var(--space-2) var(--space-4);
    min-height: 40px;
}

QMenuBar::item {
    background-color: transparent;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    margin: 0 var(--space-1);
    color: var(--color-gray-600);
    font-weight: var(--font-medium);
}

QMenuBar::item:selected {
    background-color: var(--color-primary-50);
    color: var(--color-primary-600);
}

QMenuBar::item:pressed {
    background-color: var(--color-primary-100);
}

/* ----------------------------------------------------------------------------
   菜单 - 卡片式弹出
   ---------------------------------------------------------------------------- */
QMenu {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-2);
    /* 优雅阴影 */
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
}

QMenu::item {
    padding: var(--space-3) var(--space-5);
    padding-left: var(--space-8);
    border-radius: var(--radius-md);
    margin: var(--space-1) 0;
    color: var(--color-gray-700);
    font-weight: var(--font-medium);
}

QMenu::item:selected {
    background-color: var(--color-primary-50);
    color: var(--color-primary-600);
}

QMenu::separator {
    height: 1px;
    background-color: var(--color-gray-200);
    margin: var(--space-2) var(--space-3);
}

QMenu::icon {
    padding-left: var(--space-3);
    padding-right: var(--space-3);
}

/* ----------------------------------------------------------------------------
   工具栏 - 30% 辅助色区域
   ---------------------------------------------------------------------------- */
QToolBar {
    background-color: var(--color-gray-0);
    border: none;
    border-bottom: 1px solid var(--color-gray-200);
    padding: var(--space-3) var(--space-4);
    spacing: var(--space-2);
}

QToolBar::separator {
    width: 1px;
    background-color: var(--color-gray-200);
    margin: var(--space-2) var(--space-3);
}

/* ----------------------------------------------------------------------------
   工具按钮 - 幽灵按钮风格
   ---------------------------------------------------------------------------- */
QToolButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    color: var(--color-gray-600);
    font-weight: var(--font-medium);
    transition: all var(--transition-fast);
}

QToolButton:hover {
    background-color: var(--color-gray-100);
    border-color: var(--color-gray-200);
    color: var(--color-gray-800);
}

QToolButton:pressed {
    background-color: var(--color-gray-200);
}

QToolButton:checked {
    background-color: var(--color-primary-50);
    border-color: var(--color-primary-200);
    color: var(--color-primary-600);
}

/* ----------------------------------------------------------------------------
   按钮 - 主要/次要/危险三种变体
   ---------------------------------------------------------------------------- */

/* 基础按钮 */
QPushButton {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-5);
    color: var(--color-gray-700);
    font-weight: var(--font-semibold);
    font-size: var(--text-md);
    min-height: 36px;
    min-width: 80px;
    transition: all var(--transition-fast);
}

QPushButton:hover {
    background-color: var(--color-gray-50);
    border-color: var(--color-gray-400);
}

QPushButton:pressed {
    background-color: var(--color-gray-100);
    transform: translateY(1px);
}

QPushButton:disabled {
    background-color: var(--color-gray-100);
    color: var(--color-gray-400);
    border-color: var(--color-gray-200);
}

QPushButton:focus {
    border-color: var(--color-primary-500);
    outline: none;
}

/* 主要按钮 - 10% 强调色 */
QPushButton#extractBtn,
QPushButton#primaryBtn {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
    color: var(--color-gray-0);
    box-shadow: var(--shadow-sm);
}

QPushButton#extractBtn:hover,
QPushButton#primaryBtn:hover {
    background-color: var(--color-primary-700);
    border-color: var(--color-primary-700);
    box-shadow: var(--shadow-md);
}

QPushButton#extractBtn:pressed,
QPushButton#primaryBtn:pressed {
    background-color: var(--color-primary-700);
    box-shadow: none;
}

QPushButton#extractBtn:disabled,
QPushButton#primaryBtn:disabled {
    background-color: var(--color-primary-200);
    border-color: var(--color-primary-200);
    color: var(--color-gray-0);
    box-shadow: none;
}

/* 危险按钮 */
QPushButton#clearBtn,
QPushButton#deleteBtn,
QPushButton#dangerBtn {
    background-color: var(--color-error-600);
    border-color: var(--color-error-600);
    color: var(--color-gray-0);
}

QPushButton#clearBtn:hover,
QPushButton#deleteBtn:hover,
QPushButton#dangerBtn:hover {
    background-color: var(--color-error-500);
    border-color: var(--color-error-500);
}

QPushButton#clearBtn:pressed,
QPushButton#deleteBtn:pressed,
QPushButton#dangerBtn:pressed {
    background-color: #b91c1c;
}

/* 次要/幽灵按钮 */
QPushButton#secondaryBtn {
    background-color: transparent;
    border-color: var(--color-gray-300);
    color: var(--color-gray-600);
}

QPushButton#secondaryBtn:hover {
    background-color: var(--color-gray-100);
    border-color: var(--color-gray-400);
    color: var(--color-gray-800);
}

/* 成功按钮 */
QPushButton#successBtn {
    background-color: var(--color-success-600);
    border-color: var(--color-success-600);
    color: var(--color-gray-0);
}

QPushButton#successBtn:hover {
    background-color: var(--color-success-500);
    border-color: var(--color-success-500);
}

/* ----------------------------------------------------------------------------
   文本编辑框 - 卡片风格
   ---------------------------------------------------------------------------- */
QTextEdit {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    color: var(--color-gray-800);
    font-size: var(--text-md);
    line-height: 1.6;
    selection-background-color: var(--color-primary-200);
    transition: all var(--transition-fast);
}

QTextEdit:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
}

QTextEdit:disabled {
    background-color: var(--color-gray-100);
    color: var(--color-gray-400);
    border-color: var(--color-gray-200);
}

QTextEdit::placeholder {
    color: var(--color-gray-400);
}

/* ----------------------------------------------------------------------------
   单行输入框
   ---------------------------------------------------------------------------- */
QLineEdit {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    color: var(--color-gray-800);
    font-size: var(--text-md);
    min-height: 36px;
    selection-background-color: var(--color-primary-200);
    transition: all var(--transition-fast);
}

QLineEdit:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
}

QLineEdit:disabled {
    background-color: var(--color-gray-100);
    color: var(--color-gray-400);
}

QLineEdit::placeholder {
    color: var(--color-gray-400);
}

/* ----------------------------------------------------------------------------
   标签 - 清晰的视觉层级
   ---------------------------------------------------------------------------- */
QLabel {
    color: var(--color-gray-700);
    background-color: transparent;
}

/* 大标题 - 用于面板标题 */
QLabel#titleLabel {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-2);
}

/* 小标题 */
QLabel#subtitleLabel {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--color-gray-800);
}

/* 正文/描述 */
QLabel#descriptionLabel {
    font-size: var(--text-base);
    color: var(--color-gray-600);
    line-height: 1.5;
}

/* 辅助文字 */
QLabel#hintLabel {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
}

/* 字符计数 */
QLabel#charCountLabel {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    font-weight: var(--font-medium);
}

/* ----------------------------------------------------------------------------
   分组框 - 卡片容器
   ---------------------------------------------------------------------------- */
QGroupBox {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    margin-top: var(--space-6);
    padding: var(--space-6);
    font-weight: var(--font-semibold);
    color: var(--color-gray-800);
    /* 柔和阴影 */
    box-shadow: var(--shadow-sm);
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: var(--space-4);
    padding: 0 var(--space-2);
    color: var(--color-gray-700);
    font-size: var(--text-md);
}

/* ----------------------------------------------------------------------------
   标签页 - 现代风格
   ---------------------------------------------------------------------------- */
QTabWidget::pane {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    top: -1px;
    padding: var(--space-4);
}

QTabBar::tab {
    background-color: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: var(--space-3) var(--space-5);
    margin-right: var(--space-1);
    color: var(--color-gray-500);
    font-weight: var(--font-medium);
    font-size: var(--text-md);
}

QTabBar::tab:selected {
    color: var(--color-primary-600);
    border-bottom-color: var(--color-primary-600);
}

QTabBar::tab:hover:!selected {
    color: var(--color-gray-700);
    background-color: var(--color-gray-100);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
}

/* ----------------------------------------------------------------------------
   树形控件 - 干净简洁
   ---------------------------------------------------------------------------- */
QTreeWidget {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-2);
    outline: none;
    alternate-background-color: var(--color-gray-50);
}

QTreeWidget::item {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    margin: var(--space-1) var(--space-2);
    min-height: 32px;
}

QTreeWidget::item:selected {
    background-color: var(--color-primary-50);
    color: var(--color-primary-700);
}

QTreeWidget::item:hover:!selected {
    background-color: var(--color-gray-100);
}

QTreeWidget::branch {
    padding-left: var(--space-2);
}

QHeaderView::section {
    background-color: var(--color-gray-50);
    padding: var(--space-3) var(--space-4);
    border: none;
    border-bottom: 1px solid var(--color-gray-200);
    font-weight: var(--font-semibold);
    color: var(--color-gray-700);
    font-size: var(--text-sm);
}

/* ----------------------------------------------------------------------------
   列表控件
   ---------------------------------------------------------------------------- */
QListWidget {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-2);
    outline: none;
}

QListWidget::item {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    margin: var(--space-1) 0;
}

QListWidget::item:selected {
    background-color: var(--color-primary-50);
    color: var(--color-primary-700);
}

QListWidget::item:hover:!selected {
    background-color: var(--color-gray-100);
}

/* ----------------------------------------------------------------------------
   表格
   ---------------------------------------------------------------------------- */
QTableWidget {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    gridline-color: var(--color-gray-100);
    outline: none;
}

QTableWidget::item {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-gray-100);
}

QTableWidget::item:selected {
    background-color: var(--color-primary-50);
    color: var(--color-primary-700);
}

QTableWidget::item:hover:!selected {
    background-color: var(--color-gray-50);
}

QTableCornerButton::section {
    background-color: var(--color-gray-50);
    border: none;
}

/* ----------------------------------------------------------------------------
   复选框 - 现代风格
   ---------------------------------------------------------------------------- */
QCheckBox {
    spacing: var(--space-3);
    color: var(--color-gray-700);
    font-weight: var(--font-medium);
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-gray-400);
    border-radius: var(--radius-sm);
    background-color: var(--color-gray-0);
    transition: all var(--transition-fast);
}

QCheckBox::indicator:hover {
    border-color: var(--color-primary-500);
}

QCheckBox::indicator:checked {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
    image: url(:/icons/check-white.svg);
}

QCheckBox::indicator:indeterminate {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
}

QCheckBox::indicator:disabled {
    border-color: var(--color-gray-300);
    background-color: var(--color-gray-100);
}

/* ----------------------------------------------------------------------------
   单选按钮
   ---------------------------------------------------------------------------- */
QRadioButton {
    spacing: var(--space-3);
    color: var(--color-gray-700);
    font-weight: var(--font-medium);
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-gray-400);
    border-radius: 9px;
    background-color: var(--color-gray-0);
}

QRadioButton::indicator:hover {
    border-color: var(--color-primary-500);
}

QRadioButton::indicator:checked {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
}

/* ----------------------------------------------------------------------------
   下拉框 - 现代风格
   ---------------------------------------------------------------------------- */
QComboBox {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    padding-right: var(--space-10);
    color: var(--color-gray-800);
    font-weight: var(--font-medium);
    min-height: 36px;
    min-width: 120px;
}

QComboBox:hover {
    border-color: var(--color-gray-400);
}

QComboBox:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
}

QComboBox::drop-down {
    border: none;
    width: 32px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid var(--color-gray-500);
    width: 0;
    height: 0;
}

QComboBox QAbstractItemView {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--space-2);
    selection-background-color: var(--color-primary-50);
    selection-color: var(--color-primary-700);
    box-shadow: var(--shadow-lg);
}

/* ----------------------------------------------------------------------------
   滑动条 - 极简风格
   ---------------------------------------------------------------------------- */
QSlider::groove:horizontal {
    height: 6px;
    background-color: var(--color-gray-200);
    border-radius: 3px;
}

QSlider::sub-page:horizontal {
    background-color: var(--color-primary-500);
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 18px;
    height: 18px;
    margin: -6px 0;
    background-color: var(--color-gray-0);
    border: 2px solid var(--color-primary-500);
    border-radius: 9px;
    box-shadow: var(--shadow-sm);
}

QSlider::handle:horizontal:hover {
    background-color: var(--color-primary-50);
    box-shadow: var(--shadow-md);
}

/* ----------------------------------------------------------------------------
   进度条
   ---------------------------------------------------------------------------- */
QProgressBar {
    background-color: var(--color-gray-200);
    border-radius: var(--radius-lg);
    text-align: center;
    color: var(--color-gray-700);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    min-height: 8px;
    max-height: 8px;
}

QProgressBar::chunk {
    background-color: var(--color-primary-500);
    border-radius: var(--radius-lg);
}

/* 成功状态 */
QProgressBar#success::chunk {
    background-color: var(--color-success-500);
}

/* 警告状态 */
QProgressBar#warning::chunk {
    background-color: var(--color-warning-500);
}

/* ----------------------------------------------------------------------------
   状态栏
   ---------------------------------------------------------------------------- */
QStatusBar {
    background-color: var(--color-gray-0);
    border-top: 1px solid var(--color-gray-200);
    padding: var(--space-2) var(--space-4);
    min-height: 32px;
}

QStatusBar::item {
    border: none;
}

/* 状态栏标签 */
QStatusBar QLabel {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    padding: 0 var(--space-4);
}

/* ----------------------------------------------------------------------------
   滚动条 - 极简窄条
   ---------------------------------------------------------------------------- */
QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    margin: 4px 2px;
}

QScrollBar::handle:vertical {
    background-color: var(--color-gray-400);
    border-radius: 4px;
    min-height: 40px;
}

QScrollBar::handle:vertical:hover {
    background-color: var(--color-gray-500);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background-color: transparent;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 8px;
    margin: 2px 4px;
}

QScrollBar::handle:horizontal {
    background-color: var(--color-gray-400);
    border-radius: 4px;
    min-width: 40px;
}

QScrollBar::handle:horizontal:hover {
    background-color: var(--color-gray-500);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
}

/* ----------------------------------------------------------------------------
   对话框
   ---------------------------------------------------------------------------- */
QDialog {
    background-color: var(--color-gray-50);
}

/* ----------------------------------------------------------------------------
   分割器
   ---------------------------------------------------------------------------- */
QSplitter::handle {
    background-color: var(--color-gray-200);
}

QSplitter::handle:horizontal {
    width: 2px;
    margin: 0 2px;
}

QSplitter::handle:vertical {
    height: 2px;
    margin: 2px 0;
}

QSplitter::handle:hover {
    background-color: var(--color-primary-400);
}

/* ----------------------------------------------------------------------------
   工具提示 - 现代卡片风格
   ---------------------------------------------------------------------------- */
QToolTip {
    background-color: var(--color-gray-800);
    color: var(--color-gray-0);
    border: none;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
}

/* ----------------------------------------------------------------------------
   微调框
   ---------------------------------------------------------------------------- */
QSpinBox, QDoubleSpinBox {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    min-height: 36px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
}

QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    border: none;
    background-color: transparent;
    width: 20px;
}

/* ----------------------------------------------------------------------------
   日期时间编辑器
   ---------------------------------------------------------------------------- */
QDateTimeEdit {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    min-height: 36px;
}

QDateTimeEdit:focus {
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
}

/* ----------------------------------------------------------------------------
   框架 - 卡片容器
   ---------------------------------------------------------------------------- */
QFrame {
    border: none;
}

QFrame#cardFrame {
    background-color: var(--color-gray-0);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
}

QFrame#cardFrame:hover {
    box-shadow: var(--shadow-md);
}

/* ----------------------------------------------------------------------------
   对话按钮框
   ---------------------------------------------------------------------------- */
QDialogButtonBox {
    padding: var(--space-4);
}

/* ----------------------------------------------------------------------------
   特殊状态样式
   ---------------------------------------------------------------------------- */

/* 成功状态文字 */
QLabel#successText {
    color: var(--color-success-600);
}

/* 警告状态文字 */
QLabel#warningText {
    color: var(--color-warning-600);
}

/* 错误状态文字 */
QLabel#errorText {
    color: var(--color-error-600);
}

/* 信息状态文字 */
QLabel#infoText {
    color: var(--color-info-600);
}
